<?xml version="1.0" encoding="UTF-8"?>
<document type="com.apple.InterfaceBuilder3.CocoaTouch.XIB" version="3.0" toolsVersion="24506" targetRuntime="iOS.CocoaTouch" propertyAccessControl="none" useAutolayout="YES" useTraitCollections="YES" useSafeAreas="YES" colorMatched="YES">
    <device id="retina6_12" orientation="portrait" appearance="light"/>
    <dependencies>
        <plugIn identifier="com.apple.InterfaceBuilder.IBCocoaTouchPlugin" version="24504"/>
        <capability name="System colors in document resources" minToolsVersion="11.0"/>
        <capability name="documents saved in the Xcode 8 format" minToolsVersion="8.0"/>
    </dependencies>
    <objects>
        <placeholder placeholderIdentifier="IBFilesOwner" id="-1" userLabel="File's Owner"/>
        <placeholder placeholderIdentifier="IBFirstResponder" id="-2" customClass="UIResponder"/>
        <view contentMode="scaleToFill" id="pcs-root" customClass="ProductChangesSectionView" customModule="AAINA" customModuleProvider="target">
            <rect key="frame" x="0.0" y="0.0" width="393" height="852"/>
            <autoresizingMask key="autoresizingMask" widthSizable="YES" heightSizable="YES"/>
            <subviews>
                <stackView contentMode="scaleToFill" axis="vertical" spacing="12" translatesAutoresizingMaskIntoConstraints="NO" id="pcs-outer">
                    <rect key="frame" x="0.0" y="0.0" width="393" height="852"/>
                    <subviews>
                        <label opaque="NO" contentMode="scaleToFill" text="PRODUCT CHANGES" lineBreakMode="tailTruncation" translatesAutoresizingMaskIntoConstraints="NO" id="pcs-hdr">
                            <rect key="frame" x="0.0" y="0.0" width="393" height="14.333333333333334"/>
                            <fontDescription key="fontDescription" type="boldSystem" pointSize="12"/>
                            <color key="textColor" red="0.78000000000000003" green="0.47999999999999998" blue="0.60999999999999999" alpha="1" colorSpace="calibratedRGB"/>
                            <color key="highlightedColor" systemColor="labelColor"/>
                        </label>
                        <view contentMode="scaleToFill" translatesAutoresizingMaskIntoConstraints="NO" id="pcs-card">
                            <rect key="frame" x="0.0" y="26.333333333333314" width="393" height="825.66666666666674"/>
                            <subviews>
                                <label opaque="NO" contentMode="scaleToFill" text="Did you add or remove any products?" lineBreakMode="tailTruncation" numberOfLines="0" translatesAutoresizingMaskIntoConstraints="NO" id="pcs-qlbl">
                                    <rect key="frame" x="16" y="16.000000000000004" width="361" height="17.999999999999996"/>
                                    <fontDescription key="fontDescription" type="boldSystem" pointSize="15"/>
                                    <color key="textColor" red="0.16500000000000001" green="0.16500000000000001" blue="0.16500000000000001" alpha="1" colorSpace="custom" customColorSpace="calibratedRGB"/>
                                </label>
                                <stackView contentMode="scaleToFill" axis="vertical" spacing="8" translatesAutoresizingMaskIntoConstraints="NO" id="pcs-rowstk">
                                    <rect key="frame" x="16" y="46" width="361" height="705.66666666666663"/>
                                </stackView>
                                <button contentMode="scaleToFill" contentHorizontalAlignment="center" contentVerticalAlignment="center" lineBreakMode="middleTruncation" translatesAutoresizingMaskIntoConstraints="NO" id="pcs-addbtn">
                                    <rect key="frame" x="16" y="761.66666666666663" width="361" height="48"/>
                                    <constraints>
                                        <constraint firstAttribute="height" constant="48" id="pcs-addbtn-h"/>
                                    </constraints>
                                    <state key="normal" title="+ Add product change">
                                        <color key="titleColor" red="0.54100000000000004" green="0.54100000000000004" blue="0.54100000000000004" alpha="1" colorSpace="custom" customColorSpace="calibratedRGB"/>
                                    </state>
                                </button>
                            </subviews>
                            <constraints>
                                <constraint firstItem="pcs-qlbl" firstAttribute="top" secondItem="pcs-card" secondAttribute="top" constant="16" id="pcs-c1"/>
                                <constraint firstItem="pcs-addbtn" firstAttribute="bottom" secondItem="pcs-card" secondAttribute="bottom" constant="-16" id="pcs-c10"/>
                                <constraint firstItem="pcs-qlbl" firstAttribute="leading" secondItem="pcs-card" secondAttribute="leading" constant="16" id="pcs-c2"/>
                                <constraint firstItem="pcs-qlbl" firstAttribute="trailing" secondItem="pcs-card" secondAttribute="trailing" constant="-16" id="pcs-c3"/>
                                <constraint firstItem="pcs-rowstk" firstAttribute="top" secondItem="pcs-qlbl" secondAttribute="bottom" constant="12" id="pcs-c4"/>
                                <constraint firstItem="pcs-rowstk" firstAttribute="leading" secondItem="pcs-card" secondAttribute="leading" constant="16" id="pcs-c5"/>
                                <constraint firstItem="pcs-rowstk" firstAttribute="trailing" secondItem="pcs-card" secondAttribute="trailing" constant="-16" id="pcs-c6"/>
                                <constraint firstItem="pcs-addbtn" firstAttribute="top" secondItem="pcs-rowstk" secondAttribute="bottom" constant="10" id="pcs-c7"/>
                                <constraint firstItem="pcs-addbtn" firstAttribute="leading" secondItem="pcs-card" secondAttribute="leading" constant="16" id="pcs-c8"/>
                                <constraint firstItem="pcs-addbtn" firstAttribute="trailing" secondItem="pcs-card" secondAttribute="trailing" constant="-16" id="pcs-c9"/>
                            </constraints>
                        </view>
                    </subviews>
                </stackView>
            </subviews>
            <constraints>
                <constraint firstItem="pcs-outer" firstAttribute="top" secondItem="pcs-root" secondAttribute="top" id="pcs-r1"/>
                <constraint firstItem="pcs-outer" firstAttribute="leading" secondItem="pcs-root" secondAttribute="leading" id="pcs-r2"/>
                <constraint firstItem="pcs-outer" firstAttribute="trailing" secondItem="pcs-root" secondAttribute="trailing" id="pcs-r3"/>
                <constraint firstItem="pcs-outer" firstAttribute="bottom" secondItem="pcs-root" secondAttribute="bottom" id="pcs-r4"/>
            </constraints>
            <connections>
                <outlet property="addProductButton" destination="pcs-addbtn" id="pcs-o2"/>
                <outlet property="productCard" destination="pcs-card" id="pcs-o3"/>
                <outlet property="productRowsStack" destination="pcs-rowstk" id="pcs-o1"/>
